# Backend Environment Variables
# Database
DATABASE_URL=postgresql://tradezone:tradezone_password@localhost:5432/tradezone

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_EXPIRY=7d

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# CoinGecko API (free, no authentication needed)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_UPDATE_INTERVAL=10000

# Kraken Exchange API (https://www.kraken.com/features/api)
# Trading Provider - All crypto trading is executed through Kraken
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_PUBLIC_KEY=your-kraken-api-public-key
KRAKEN_PRIVATE_KEY=your-kraken-api-private-key
# Optional: Tier 2 keys for lower rate limits
# KRAKEN_API_TIER=starter

# Kraken Forex API (free, no authentication needed for public endpoints)
# Kraken provides real-time forex data for major currency pairs
FOREX_UPDATE_INTERVAL=15000

# Google reCAPTCHA v3
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Stock API (Finnhub - get key from https://finnhub.io)
FINNHUB_API_KEY=your-finnhub-api-key

# NFT API (OpenSea - get key from https://docs.opensea.io)
OPENSEA_API_KEY=your-opensea-api-key

# AI Trading APIs
# DeepSeek API (https://www.deepseek.com)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Google Gemini API (https://ai.google.dev)
GEMINI_API_KEY=your-gemini-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10000000
UPLOAD_DIR=./uploads

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# ========== PAYMENT GATEWAYS ==========
# Configure payment gateways for fiat deposits/withdrawals

# STRIPE Payment Gateway (https://stripe.com)
# Supports: Major global currencies, debit/credit cards
STRIPE_API_KEY=your-stripe-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# PayPal Payment Gateway (https://paypal.com)
# Supports: Major global currencies, PayPal balance, bank transfers
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox  # Options: sandbox, live
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Paystack Payment Gateway (https://paystack.com)
# Supports: African currencies (NGN, GHS, ZAR, etc.)
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# Square Payment Gateway (https://squareup.com) - Optional
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_APPLICATION_ID=your-square-application-id
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key

# Razorpay Payment Gateway (https://razorpay.com) - Optional
# Supports: Indian rupees and other currencies
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Payment Gateway Configuration
# Control which gateways are enabled and their settings
PAYMENT_GATEWAY_MODE=sandbox  # Options: sandbox, production
PAYMENT_MIN_AMOUNT=10  # Minimum deposit/withdrawal amount
PAYMENT_MAX_AMOUNT=100000  # Maximum deposit/withdrawal amount
PAYMENT_STRIPE_ENABLED=true
PAYMENT_PAYPAL_ENABLED=true
PAYMENT_PAYSTACK_ENABLED=true
PAYMENT_SQUARE_ENABLED=false
PAYMENT_RAZORPAY_ENABLED=false

# Payment Processing Fees (as percentage + fixed amount)
STRIPE_FEE_PERCENTAGE=2.9
STRIPE_FEE_FIXED=0.30
PAYPAL_FEE_PERCENTAGE=3.49
PAYPAL_FEE_FIXED=0.30
PAYSTACK_FEE_PERCENTAGE=1.5
PAYSTACK_FEE_FIXED=0

# Frontend URLs for payment callbacks
FRONTEND_URL=http://localhost:5173
PAYMENT_SUCCESS_URL=http://localhost:5173/payment/success
PAYMENT_CANCEL_URL=http://localhost:5173/payment/cancel